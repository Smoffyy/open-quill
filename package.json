{
  "name": "open-quill",
  "version": "2027.0.0-cascade.2",
  "private": true,
  "description": "Local Anthropic-style chat UI for OpenAI-compatible servers",
  "scripts": {
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm run build",
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "start": "cd server && npm start",
    "update:deps": "node update-deps.mjs",
    "check:deps": "node update-deps.mjs --check"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "overrides": {
    "shell-quote": ">=1.8.4"
  }
}
